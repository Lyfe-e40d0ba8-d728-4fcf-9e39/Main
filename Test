local _notifActive = false

local function ShowNotification(cfg)
    cfg = cfg or {}
    if _notifActive then return end
    _notifActive = true

    task.spawn(function()
        local duration = cfg.duration or cfg.Duration or 5
        local onComplete = cfg.OnComplete or cfg.onComplete

        local screen = getNotifScreen()
        local MainFrame, ProgressFill, Shimmer = BuildNotifFrame(screen, cfg)

        local targetPos = UDim2.new(1, -(notifWidth + notifPosX), 1, -(notifHeight + notifPosY))
        local exitPos = UDim2.new(1, notifWidth + 20, 1, -(notifHeight + notifPosY))

        local slideInInfo = TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        local slideOutInfo = TweenInfo.new(0.38, Enum.EasingStyle.Quint, Enum.EasingDirection.In)

        TweenService:Create(MainFrame, slideInInfo, { Position = targetPos }):Play()

        task.spawn(function()
            while MainFrame and MainFrame.Parent do
                TweenService:Create(Shimmer, TweenInfo.new(1.5, Enum.EasingStyle.Linear), {
                Position = UDim2.new(1.2, 0, 0, 0),
                }):Play()
                task.wait(3.2)
                if MainFrame and MainFrame.Parent then
                    Shimmer.Position = UDim2.new(-0.35, 0, 0, 0)
                end
            end
        end)

        TweenService:Create(ProgressFill, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
        Size = UDim2.new(0, 0, 1, 0),
        }):Play()

        task.wait(duration)

        local slideOut = TweenService:Create(MainFrame, slideOutInfo, { Position = exitPos })
        slideOut:Play()
        slideOut.Completed:Wait()

        if MainFrame and MainFrame.Parent then MainFrame:Destroy() end

        if _notifScreen and _notifScreen.Parent and #_notifScreen:GetChildren() == 0 then
            _notifScreen:Destroy()
            _notifScreen = nil
        end

        _notifActive = false
        if typeof(onComplete) == "function" then pcall(onComplete) end
    end)
end

