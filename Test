math.randomseed(os.clock() * 100000)

local charset = {}
for i = 32, 126 do
	table.insert(charset, string.char(i))
end

local weirdChar    = "?"
local WEIRD_CHANCE = 0.40

local function randomName(len)
	len = len or math.random(15, 30)
	local str = ""
	for i = 1, len do
		if math.random() < WEIRD_CHANCE then
			str = str .. weirdChar
		else
			str = str .. charset[math.random(1, #charset)]
		end
	end
	return str
end

