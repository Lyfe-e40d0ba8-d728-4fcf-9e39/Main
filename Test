    makeDraggable(ToggleFrame)

    local originalTransparencies = {}

    local function cacheOriginalValues()
        originalTransparencies = {}
        local function cacheObj(obj)
            if not obj or not obj.Parent then return end
            if obj:IsA("Frame") then
                originalTransparencies[obj] = {BackgroundTransparency = obj.BackgroundTransparency}
            elseif obj:IsA("TextLabel") then
                originalTransparencies[obj] = {TextTransparency = obj.TextTransparency, BackgroundTransparency = obj.BackgroundTransparency}
            elseif obj:IsA("TextButton") then
                originalTransparencies[obj] = {TextTransparency = obj.TextTransparency, BackgroundTransparency = obj.BackgroundTransparency}
            elseif obj:IsA("TextBox") then
                originalTransparencies[obj] = {TextTransparency = obj.TextTransparency, BackgroundTransparency = obj.BackgroundTransparency}
            elseif obj:IsA("ImageLabel") then
                originalTransparencies[obj] = {ImageTransparency = obj.ImageTransparency, BackgroundTransparency = obj.BackgroundTransparency}
            elseif obj:IsA("UIStroke") then
                originalTransparencies[obj] = {Transparency = obj.Transparency}
            elseif obj:IsA("ScrollingFrame") then
                originalTransparencies[obj] = {ScrollBarImageTransparency = obj.ScrollBarImageTransparency, BackgroundTransparency = obj.BackgroundTransparency}
            end
        end
        cacheObj(MainFrame)
        for _, desc in ipairs(MainFrame:GetDescendants()) do cacheObj(desc) end
        cacheObj(ExtraFrame)
        for _, desc in ipairs(ExtraFrame:GetDescendants()) do cacheObj(desc) end
    end

    task.delay(0.1, cacheOriginalValues)

    local function fadeAllTo(targetAlpha, dur, callback)
        local tweenI = TweenInfo.new(dur, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        for obj, props in pairs(originalTransparencies) do
            if obj and obj.Parent then
                local tp = {}
                for pn, ov in pairs(props) do
                    tp[pn] = (targetAlpha == 0) and ov or 1
                end
                if next(tp) then TweenService:Create(obj, tweenI, tp):Play() end
            end
        end
        if callback then task.delay(dur, callback) end
    end

    local function toggleGUI()
        if isAnimating then return end
        isAnimating = true
        mainVisible = not mainVisible
        local fd = 0.3
        if mainVisible then
            MainFrame.Visible = true
            ExtraFrame.Visible = true
            ToggleText.Text = "HIDE"
            TweenService:Create(tAccentBar, TWEEN_NORMAL,
            {BackgroundColor3 = RX.Accent1}):Play()
            fadeAllTo(0, fd, function() isAnimating = false end)
        else
            ToggleText.Text = "OPEN"
            TweenService:Create(tAccentBar, TWEEN_NORMAL,
            {BackgroundColor3 = RX.Red}):Play()
            fadeAllTo(1, fd, function()
                if not mainVisible then
                    MainFrame.Visible = false
                    ExtraFrame.Visible = false
                end
                isAnimating = false
            end)
        end
    end

    ToggleFrame.MouseButton1Click:Connect(toggleGUI)
    ToggleFrame.TouchTap:Connect(toggleGUI)

end -- OnComplete
