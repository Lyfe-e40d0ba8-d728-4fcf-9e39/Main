        -- Gold Premium Color
        local GOLD = Color3.fromRGB(255, 215, 0)

        -- ── Fungsi format waktu ──────────────────────────────────────────
        local function formatTimer(totalSeconds)
            if totalSeconds <= 0 then
                return nil -- expired
            end
            local days    = math.floor(totalSeconds / 86400)
            local hours   = math.floor((totalSeconds % 86400) / 3600)
            local minutes = math.floor((totalSeconds % 3600) / 60)
            return string.format("%04dD : %02dH : %02dM", days, hours, minutes)
        end

        -- ── Baca data dari Key System & jalankan timer ───────────────────
        local function startKeyTimer()
            local keyData = getgenv and getgenv()._FlycerKeyData

            -- Tidak ada key
            if not keyData then
                timerLabel.Text      = "NO KEY"
                timerLabel.TextColor3 = RX.Red
                return
            end

            local keyType         = keyData.keyType
            local expireTimestamp = keyData.expireTimestamp

            -- LIFETIME → Gold, tidak ada countdown
            if keyType == "lifetime" then
                timerLabel.Text       = "LIFETIME ACCESS"
                timerLabel.TextColor3 = GOLD
                return
            end

            -- FREE tanpa expire → Gold, tidak ada countdown
            if keyType == "free" and not expireTimestamp then
                timerLabel.Text       = "FREE : UNLIMITED"
                timerLabel.TextColor3 = GOLD
                return
            end

            -- FREE dengan expire / DURATION → Green, countdown tiap menit
            if expireTimestamp then
                local expireTime = tonumber(expireTimestamp)

                task.spawn(function()
                    while timerLabel and timerLabel.Parent do
                        local remaining = expireTime - os.time()
                        local formatted = formatTimer(remaining)

                        if not formatted then
                            -- Sudah expired
                            timerLabel.Text       = "EXPIRED"
                            timerLabel.TextColor3 = RX.Red
                            break
                        end

                        timerLabel.Text       = formatted
                        timerLabel.TextColor3 = RX.Green -- selalu Green selama belum expired
                        task.wait(60) -- update setiap 1 menit
                    end
                end)
            end
        end

        task.defer(startKeyTimer)

