	--  Cache nilai ASLI dulu (sebelum disembunyikan)
	--  lalu sembunyikan semua → fade masuk
	--  Ini persis sama dengan sistem HIDE/OPEN GUI
	-- ══════════════════════════════════════════════════════════════
	local originalTrans = {}

	local function cacheObj(obj)
		if not obj or not obj.Parent then return end
		local t = {}
		if obj:IsA("Frame") then
			t.BackgroundTransparency = obj.BackgroundTransparency
		end
		if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
			t.BackgroundTransparency = obj.BackgroundTransparency
			t.TextTransparency       = obj.TextTransparency
		end
		if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
			t.BackgroundTransparency = obj.BackgroundTransparency
			t.ImageTransparency      = obj.ImageTransparency
		end
		if obj:IsA("UIStroke") then
			t.Transparency = obj.Transparency
		end
		if obj:IsA("ScrollingFrame") then
			t.BackgroundTransparency     = obj.BackgroundTransparency
			t.ScrollBarImageTransparency = obj.ScrollBarImageTransparency
		end
		if next(t) then
			originalTrans[obj] = t
		end
	end

	-- Step 1: Cache nilai asli semua object (saat ini masih terlihat)
	cacheObj(ResizePanel)
	cacheObj(Overlay)
	for _, d in ipairs(ResizePanel:GetDescendants()) do
		cacheObj(d)
	end

	-- Step 2: Sembunyikan semua secara instan (tanpa tween)
	local function hideAllInstant()
		for obj, props in pairs(originalTrans) do
			if obj and obj.Parent then
				for propName, _ in pairs(props) do
					pcall(function() obj[propName] = 1 end)
				end
			end
		end
	end

	-- Step 3: Fade masuk (kembalikan ke nilai asli)
	local function fadePanelTo(targetAlpha, dur, callback)
		local tweenI = TweenInfo.new(dur, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
		for obj, props in pairs(originalTrans) do
			if obj and obj.Parent then
				local tp = {}
				for propName, origVal in pairs(props) do
					tp[propName] = (targetAlpha == 0) and origVal or 1
				end
				if next(tp) then
					TweenService:Create(obj, tweenI, tp):Play()
				end
			end
		end
		if callback then
			task.delay(dur, callback)
		end
	end

	-- ── Fungsi tutup (satu pintu keluar) ──────────────────────────
	local function closeResizeGui(callback)
		if isClosing then return end
		isClosing = true
