				end)

				pcall(function()
					ShowNotification({
						title    = "Resize GUI",
						body     = string.format("Ukuran: %d × %d px", wVal, hVal),
						duration = 3,
					})
				end)
			end)
		end)

		task.delay(2.5, function() applyDebounce = false end)
	end

	changeBtn.MouseButton1Click:Connect(applyResize)
