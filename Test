local function CreateTroopsRapidFireToggle(layoutOrder)
    local rapidFireEnabled = false
    local rapidFireSpeed = 20
    local rapidFireThread = nil

    local function DoCombatForRapidFire()
        local formation = workspace:FindFirstChild("Formation")
        if not formation then return end
        local children = formation:GetChildren()
        for _, unit in ipairs(children) do
            if not rapidFireEnabled then return end
            if unit.Name:find("Player") then
                local action = unit:FindFirstChild("Action")
                if action then
                    for _, target in ipairs(children) do
                        if not rapidFireEnabled then return end
                        if target.Name:find("Defender") then
                            pcall(function()
                                if action:IsA("RemoteEvent") then
                                    action:FireServer(target)
                                else
                                    action:Fire(target)
                                end
                            end)
                        end
                    end
                end
            end
        end
    end

    local function RunRapidFire()
        rapidFireThread = task.spawn(function()
            while rapidFireEnabled do
