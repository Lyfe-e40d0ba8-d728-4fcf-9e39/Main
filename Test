local function getSafeParent()
    if get_hidden_ui then return get_hidden_ui()
    elseif gethui then return gethui()
    elseif syn and syn.protect_gui then return CoreGui
    else return CoreGui end
    end

    getgenv().Flycer_SafeParent = getSafeParent()

    local DRAG_SMOOTHNESS = 20

    local function getDragLerpAlpha(smoothValue)
        smoothValue = math.clamp(smoothValue or DRAG_SMOOTHNESS, 1, 20)
        return 1.0 - ((smoothValue - 1) / 19) * 0.9
    end

    local function makeDraggable(dragHandle, dragTarget, smoothness)
        local dragging = false
        local dragStart = nil
        local startPos = nil
        local activeTouch = nil
        local targetPosition = nil
        local lerpThread = nil
        local lerpRunning = false

        dragTarget = dragTarget or dragHandle

        local lerpAlpha = getDragLerpAlpha(smoothness)
        local smoothVal = math.clamp(smoothness or DRAG_SMOOTHNESS, 1, 20)
        local useLerp = smoothVal > 3

        local function startLerpLoop()
            if lerpRunning then return end
            lerpRunning = true
            lerpThread = task.spawn(function()
                while lerpRunning do
                    if dragging and targetPosition then
                        local cp = dragTarget.Position
                        local newX = cp.X.Offset + (targetPosition.X - cp.X.Offset) * lerpAlpha
                        local newY = cp.Y.Offset + (targetPosition.Y - cp.Y.Offset) * lerpAlpha
                        if math.abs(targetPosition.X - newX) < 0.5
                        and math.abs(targetPosition.Y - newY) < 0.5 then
                            dragTarget.Position = UDim2.new(cp.X.Scale, targetPosition.X, cp.Y.Scale, targetPosition.Y)
                        else
                            dragTarget.Position = UDim2.new(cp.X.Scale, newX, cp.Y.Scale, newY)
                        end
                    end
                    task.wait()
                end
            end)
        end

        local function stopLerpLoop()
            lerpRunning = false
            if lerpThread then
                pcall(function() task.cancel(lerpThread) end)
                lerpThread = nil
            end
        end

        local function update(input)
            if not dragging or not dragStart or not startPos then return end
            local delta = input.Position - dragStart
            if useLerp then
                targetPosition = Vector2.new(
                startPos.X.Offset + delta.X,
                startPos.Y.Offset + delta.Y
                )
            else
                dragTarget.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
            end
        end

        dragHandle.InputBegan:Connect(function(input)
            local it = input.UserInputType
            if it ~= Enum.UserInputType.MouseButton1
            and it ~= Enum.UserInputType.Touch then return end
            if dragging then return end

            dragging = true
            dragStart = input.Position
            startPos = dragTarget.Position
            targetPosition = Vector2.new(startPos.X.Offset, startPos.Y.Offset)
            if it == Enum.UserInputType.Touch then activeTouch = input end
            if useLerp then startLerpLoop() end

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    if input == activeTouch then activeTouch = nil end
                    if useLerp then
                        task.delay(0.15, function()
                            if not dragging then
                                stopLerpLoop()
                                targetPosition = nil
                            end
                        end)
                    end
                    dragStart = nil
                    startPos = nil
                end
            end)
        end)

        UserInputService.InputChanged:Connect(function(input)
            if not dragging then return end
            local it = input.UserInputType
            if it == Enum.UserInputType.MouseMovement then
                update(input)
            elseif it == Enum.UserInputType.Touch and input == activeTouch then
                update(input)
            end
        end)
    end

    -- ── Random Name ───────────────────────────────────────────────────
    math.randomseed(os.clock() * 100000)

    local charset = {}
    for i = 32, 126 do
        table.insert(charset, string.char(i))
    end

    local weirdChar = "�"
    local WEIRD_CHANCE = 0.40

    local function randomName(len)
        len = len or math.random(15, 30)
        local str = ""

        for i = 1, len do
            if math.random() < WEIRD_CHANCE then
                str = str .. weirdChar
            else
                str = str .. charset[math.random(1, #charset)]
            end
        end

        return str
    end

    local GUI_NAME = "SettingsMenu"
    local FLAG_NAME = "_FlycerGUI_Loaded"
    local GUI_REF_NAME = "_FlycerGUI_Instance"

    local parent = (syn and syn.protect_gui and CoreGui)
    or (get_hidden_ui and get_hidden_ui())
    or (gethui and gethui())
    or CoreGui

    local function destroyExistingFlycer()
        local g = getgenv and getgenv() or _G
        if g[FLAG_NAME] then
            local old = g[GUI_REF_NAME]
            if old and typeof(old) == "Instance" and old:IsA("ScreenGui") then
                pcall(function() old:Destroy(); g[GUI_REF_NAME] = nil end)
            end
        end
        g[FLAG_NAME] = true
    end

    if getgenv()._FlycerGUI then
        pcall(function() getgenv()._FlycerGUI:Destroy() end)
    end

    local function removeOldFlycerGUI()
        local containers = {
        CoreGui,
        LocalPlayer:FindFirstChild("PlayerGui"),
        (get_hidden_ui and get_hidden_ui()) or nil,
        (gethui and gethui()) or nil,
        parent,
    }
    for _, c in ipairs(containers) do
        if c then
            for _, ch in ipairs(c:GetChildren()) do
                if ch:IsA("ScreenGui") and ch.Name == GUI_NAME then
                    pcall(function() ch:Destroy() end)
                end
            end
        end
    end
end

